<script>
async function exportSlide(n) {
  const btn = document.getElementById('btn' + n);
  const el  = document.getElementById('s' + n);
  const names = ['','Capa','Diagnostico','PorQueAcontece','Exercicio_1','Exercicio_2','OQueMuda','CTA'];

  btn.textContent = '⏳ Renderizando...';
  btn.disabled = true;
  document.getElementById('status').textContent = 'Renderizando slide ' + n + ' de 7 — aguarde...';

  try {
    // Hide nav controls temporarily
    const canvas = await html2canvas(el, {
      scale: 1,
      width: 1080,
      height: 1350,
      useCORS: true,
      allowTaint: true,
      backgroundColor: null,
      logging: false,
      imageTimeout: 20000,
      onclone: (cloned) => {
        // Ensure fonts are loaded in clone
        const style = cloned.createElement('style');
        style.textContent = "@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap');";
        cloned.head.appendChild(style);
      }
    });

    const link = document.createElement('a');
    link.download = 'post8_slide' + String(n).padStart(2,'0') + '_' + names[n] + '_joaopaulosico.png';
    link.href = canvas.toDataURL('image/png', 1.0);
    link.click();

    btn.textContent = '✓ Baixado!';
    btn.classList.add('done');
    document.getElementById('status').textContent = '✓ Slide ' + n + ' exportado! (' + names[n] + ')';

  } catch(err) {
    btn.textContent = '⬇ Tentar novamente';
    btn.disabled = false;
    document.getElementById('status').textContent = '⚠ Erro no slide ' + n + ': ' + err.message;
    console.error('html2canvas error on slide ' + n, err);
  }
}

async function exportAll() {
  const btnAll = document.getElementById('btnAll');
  btnAll.textContent = '⏳ Exportando...';
  btnAll.disabled = true;

  for (let i = 1; i <= 7; i++) {
    await exportSlide(i);
    await new Promise(r => setTimeout(r, 1200)); // gap between downloads
  }

  btnAll.textContent = '✓ Todos exportados!';
  document.getElementById('status').textContent = '✓ Todos os 7 slides foram exportados como PNG 1080×1350px.';
}

// Wait for fonts to load
document.fonts.ready.then(() => {
  document.getElementById('status').textContent = 'Fontes carregadas. Pronto para exportar!';
});
</script>
