<style>
* { margin:0; padding:0; box-sizing:border-box; }
:root {
  --brand: #BF7D30;
  --brand-l: #D9A868;
  --brand-d: #8C5A22;
  --light: #F3EDE3;
  --light-b: #E6DDD0;
  --dark: #0E0D0B;
  --f: 'Space Grotesk', sans-serif;
}
body { background:#111; font-family:var(--f); padding:32px; display:flex; flex-direction:column; align-items:center; gap:0; }

/* ─── TOOLBAR ─── */
.toolbar {
  width:1080px; background:#1E1E1E; border:1px solid #2E2E2E;
  border-radius:14px; padding:20px 28px; margin-bottom:32px;
  display:flex; align-items:center; gap:16px; flex-wrap:wrap;
}
.toolbar h2 { font-size:15px; color:#fff; font-weight:600; margin-right:auto; }
.toolbar p { font-size:12px; color:#666; line-height:1.5; }
.btn-all {
  background:var(--brand); color:#fff; border:none; border-radius:24px;
  padding:12px 28px; font-family:var(--f); font-size:13px; font-weight:700;
  cursor:pointer; transition:background .2s; white-space:nowrap;
}
.btn-all:hover { background:var(--brand-d); }
.btn-all:disabled { background:#444; cursor:wait; }
.status { font-size:12px; color:#888; font-style:italic; width:100%; }

/* ─── AUDIT BADGE ─── */
.audit {
  width:1080px; background:#1A2A1A; border:1px solid #2A4A2A;
  border-radius:14px; padding:18px 28px; margin-bottom:32px;
}
.audit h3 { font-size:13px; color:#6FCF6F; font-weight:700; letter-spacing:1px; text-transform:uppercase; margin-bottom:12px; }
.audit-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:12px; }
.ach { background:rgba(0,200,0,0.06); border:1px solid rgba(0,200,0,0.15); border-radius:8px; padding:10px 14px; }
.ach .lbl { font-size:10px; color:#6FCF6F; font-weight:600; letter-spacing:1px; text-transform:uppercase; margin-bottom:4px; }
.ach .val { font-size:13px; color:#fff; font-weight:600; }

/* ─── SLIDE WRAPPER ─── */
.slide-wrapper { display:flex; align-items:flex-start; gap:16px; margin-bottom:28px; }
.ctrl { display:flex; flex-direction:column; gap:8px; padding-top:8px; min-width:110px; }
.snum { font-size:11px; color:#555; text-align:center; font-weight:700; letter-spacing:1px; text-transform:uppercase; }
.btn-dl {
  background:#2A2A2A; color:#ccc; border:1px solid #3A3A3A; border-radius:10px;
  padding:11px 14px; font-family:var(--f); font-size:12px; font-weight:600;
  cursor:pointer; white-space:nowrap; transition:all .2s; text-align:center;
}
.btn-dl:hover { background:var(--brand); color:#fff; border-color:var(--brand); }
.btn-dl.done { background:#1A3A1A; color:#6FCF6F; border-color:#2A5A2A; }
.btn-dl:disabled { opacity:0.5; cursor:wait; }
.sname { font-size:10px; color:#444; text-align:center; line-height:1.4; }

/* ─── SLIDE BASE ─── */
.slide {
  width:1080px; height:1350px;
  position:relative; overflow:hidden;
  display:flex; flex-direction:column; flex-shrink:0;
  font-family:var(--f);
}

/* PROGRESS BAR */
.pb { position:absolute; bottom:0; left:0; right:0; padding:36px 68px 42px; z-index:10; display:flex; align-items:center; gap:22px; }
.pb-t { flex:1; height:4px; border-radius:3px; overflow:hidden; }
.pb-f { height:100%; border-radius:3px; }
.pb-n { font-size:22px; font-weight:600; letter-spacing:0.5px; font-family:var(--f); }

.dk .pb-t { background:rgba(255,255,255,0.07); }
.dk .pb-f { background:rgba(255,255,255,0.42); }
.dk .pb-n { color:rgba(255,255,255,0.22); }
.lt .pb-t { background:rgba(0,0,0,0.07); }
.lt .pb-f { background:var(--brand); }
.lt .pb-n { color:rgba(0,0,0,0.18); }
.gr .pb-t { background:rgba(255,255,255,0.14); }
.gr .pb-f { background:rgba(255,255,255,0.52); }
.gr .pb-n { color:rgba(255,255,255,0.32); }

/* SWIPE HINT */
.sw { position:absolute; right:44px; bottom:100px; z-index:9; opacity:0.35; }

/* TAG */
.tag { font-size:22px; font-weight:700; letter-spacing:4px; text-transform:uppercase; margin-bottom:48px; font-family:var(--f); }
.dk .tag { color:var(--brand-l); }
.lt .tag { color:var(--brand); }

/* ══════════════════════════
   SLIDE 1 — CAPA
══════════════════════════ */
.s1 { background:var(--dark); justify-content:flex-end; }
.s1 .pbg { position:absolute; inset:0; background-image:url('https://lh3.googleusercontent.com/d/16cGIZTHUGtz-C8pgW6d0nIMf9_Die76Z'); background-size:cover; background-position:center top; }
.s1 .pov { position:absolute; inset:0; background:linear-gradient(to bottom, rgba(14,13,11,0) 0%, rgba(14,13,11,0.05) 30%, rgba(14,13,11,0.72) 60%, rgba(14,13,11,0.97) 100%); }
.s1 .cnt { position:relative; z-index:2; padding:0 78px 100px; }
.btag { display:inline-flex; align-items:center; gap:16px; margin-bottom:36px; }
.bdot { width:14px; height:14px; border-radius:50%; background:var(--brand); flex-shrink:0; }
.bname { font-size:22px; font-weight:700; letter-spacing:5px; text-transform:uppercase; color:var(--brand-l); font-family:var(--f); }
.aline { width:82px; height:5px; background:var(--brand); border-radius:3px; margin-bottom:38px; }
.mhook { font-size:66px; font-weight:700; color:#fff; line-height:1.05; letter-spacing:-1.5px; margin-bottom:24px; font-family:var(--f); }
.shook { font-size:32px; font-weight:400; color:rgba(255,255,255,0.44); line-height:1.4; font-family:var(--f); }

/* ══════════════════════════
   SLIDE 2 — DIAGNÓSTICO
══════════════════════════ */
.s2 { background:var(--dark); justify-content:flex-end; padding:0 78px 110px; }
.s2-main { font-size:80px; font-weight:700; color:#fff; line-height:1.0; letter-spacing:-2px; margin-bottom:58px; font-family:var(--f); }
.s2-div { width:100%; height:1px; background:rgba(255,255,255,0.06); margin-bottom:48px; }
.s2-det { font-size:36px; color:rgba(255,255,255,0.46); line-height:1.5; margin-bottom:14px; font-family:var(--f); }
.s2-det em { color:rgba(255,255,255,0.88); font-style:normal; font-weight:500; }

/* ══════════════════════════
   SLIDE 3 — POR QUE ACONTECE
══════════════════════════ */
.s3 { background:var(--light); justify-content:flex-end; padding:0 78px 110px; }
.cgrid { display:grid; grid-template-columns:1fr 1fr; gap:24px; margin-bottom:46px; }
.cc { padding:40px; border-radius:24px; border:1px solid var(--light-b); background:rgba(255,255,255,0.65); }
.cc.dk2 { background:var(--dark); border-color:transparent; }
.cl { font-size:20px; font-weight:700; letter-spacing:3px; text-transform:uppercase; color:var(--brand); margin-bottom:18px; font-family:var(--f); }
.cc.dk2 .cl { color:var(--brand-l); }
.cw { font-size:44px; font-weight:700; color:var(--dark); margin-bottom:10px; font-family:var(--f); }
.cc.dk2 .cw { color:#fff; }
.cd { font-size:28px; color:#9A9088; line-height:1.4; font-family:var(--f); }
.cc.dk2 .cd { color:rgba(255,255,255,0.42); }
.ibox { background:var(--dark); border-radius:24px; padding:38px 44px; }
.itxt { font-size:34px; color:rgba(255,255,255,0.76); line-height:1.55; font-family:var(--f); }
.itxt strong { color:var(--brand-l); font-weight:600; }

/* ══════════════════════════
   SLIDE 4 — EXERCÍCIO PT1
══════════════════════════ */
.s4 { background:var(--dark); justify-content:flex-end; padding:0 78px 110px; }
.fcard { background:rgba(255,255,255,0.025); border:1px solid rgba(255,255,255,0.07); border-radius:28px; padding:46px; margin-bottom:28px; }
.flbl { font-size:18px; font-weight:700; letter-spacing:3px; text-transform:uppercase; color:rgba(255,255,255,0.18); margin-bottom:24px; font-family:var(--f); }
.fline { font-size:34px; color:rgba(255,255,255,0.58); line-height:2.1; font-family:var(--f); }
.ff { display:inline-block; background:rgba(191,125,48,0.15); border:1px dashed rgba(191,125,48,0.4); border-radius:10px; padding:2px 18px; color:var(--brand-l); font-weight:600; font-size:32px; font-family:var(--f); }
.ecard { background:rgba(191,125,48,0.065); border:1px solid rgba(191,125,48,0.15); border-radius:24px; padding:34px 40px; }
.elbl { font-size:18px; font-weight:700; letter-spacing:3px; text-transform:uppercase; color:rgba(191,125,48,0.42); margin-bottom:14px; font-family:var(--f); }
.etxt { font-size:30px; color:rgba(255,255,255,0.66); line-height:1.55; font-style:italic; font-family:var(--f); }

/* ══════════════════════════
   SLIDE 5 — EXERCÍCIO PT2
══════════════════════════ */
.s5 { background:var(--light); justify-content:flex-end; padding:0 78px 110px; }
.slbl { font-size:70px; font-weight:700; color:var(--dark); margin-bottom:12px; letter-spacing:-1px; font-family:var(--f); }
.ssub { font-size:34px; color:#7A7068; margin-bottom:48px; line-height:1.4; font-family:var(--f); }
.cklist { display:flex; flex-direction:column; gap:20px; margin-bottom:38px; }
.chi { display:flex; align-items:center; gap:28px; padding:30px 36px; background:rgba(255,255,255,0.65); border:1px solid var(--light-b); border-radius:24px; }
.chc { width:52px; height:52px; border-radius:50%; border:2.5px solid var(--brand); display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.chtxt { font-size:32px; color:var(--dark); line-height:1.4; font-weight:500; font-family:var(--f); }
.wbox { background:var(--dark); border-radius:24px; padding:30px 36px; display:flex; align-items:flex-start; gap:22px; }
.wico { font-size:32px; color:var(--brand-l); font-weight:700; flex-shrink:0; margin-top:2px; font-family:var(--f); }
.wtxt { font-size:30px; color:rgba(255,255,255,0.72); line-height:1.5; font-family:var(--f); }
.wtxt strong { color:var(--brand-l); font-weight:600; }

/* ══════════════════════════
   SLIDE 6 — O QUE MUDA
══════════════════════════ */
.s6 { background:var(--dark); justify-content:flex-end; padding:0 78px 110px; }
.stitle { font-size:58px; font-weight:700; color:#fff; margin-bottom:48px; letter-spacing:-1px; line-height:1.1; font-family:var(--f); }
.clist { display:flex; flex-direction:column; gap:0; margin-bottom:40px; }
.ci { display:flex; align-items:center; gap:32px; padding:26px 0; border-bottom:1px solid rgba(255,255,255,0.05); }
.ci:last-child { border-bottom:none; }
.carr { width:62px; height:62px; border-radius:18px; background:rgba(191,125,48,0.1); border:1px solid rgba(191,125,48,0.2); display:flex; align-items:center; justify-content:center; flex-shrink:0; font-size:28px; color:var(--brand-l); font-weight:700; font-family:var(--f); }
.ctxt { font-size:34px; color:rgba(255,255,255,0.64); font-family:var(--f); }
.ctxt strong { color:#fff; font-weight:600; }
.cbox { background:rgba(191,125,48,0.07); border:1px solid rgba(191,125,48,0.15); border-radius:24px; padding:32px 40px; }
.cbotxt { font-size:32px; color:rgba(255,255,255,0.78); line-height:1.55; font-family:var(--f); }
.cbotxt strong { color:var(--brand-l); font-weight:600; }

/* ══════════════════════════
   SLIDE 7 — CTA
══════════════════════════ */
.s7 {
  background:linear-gradient(148deg, #3A1A06 0%, #6B3B14 22%, #8C5A22 50%, #BF7D30 78%, #D9A868 100%);
  align-items:center; justify-content:center; text-align:center; padding:0 88px;
}
.lm { width:138px; height:138px; border-radius:50%; background:rgba(255,255,255,0.11); border:2px solid rgba(255,255,255,0.22); display:flex; align-items:center; justify-content:center; margin-bottom:56px; padding:28px; overflow:hidden; }
.lm img { width:100%; height:100%; object-fit:contain; filter:invert(1); }
.cth { font-size:100px; font-weight:700; color:#fff; letter-spacing:-3px; line-height:0.95; margin-bottom:26px; font-family:var(--f); }
.csub { font-size:34px; color:rgba(255,255,255,0.58); line-height:1.55; margin-bottom:68px; max-width:680px; font-family:var(--f); }
.cbtn { display:inline-flex; align-items:center; gap:18px; padding:32px 68px; background:rgba(255,255,255,0.1); border:2px solid rgba(255,255,255,0.28); border-radius:80px; font-size:30px; font-weight:600; color:#fff; margin-bottom:48px; letter-spacing:0.3px; font-family:var(--f); }
.hnd { font-size:26px; color:rgba(255,255,255,0.38); letter-spacing:1px; font-family:var(--f); }
</style>
</head>
